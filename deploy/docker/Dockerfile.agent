FROM golang:1.23-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /bin/lens-agent ./cmd/agent

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /bin/lens-agent /usr/local/bin/lens-agent

RUN mkdir -p /var/lib/lens/buffer /etc/lens

EXPOSE 4317 9090

ENTRYPOINT ["lens-agent"]
